  },
  "browserslist": {
    "production": [
      "chrome >= 109",
      "edge >= 109",
      "firefox >= 115",
      "safari >= 16.4",
      "ios_saf >= 16.4"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=24.0.0"
  }
