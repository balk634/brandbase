{
  "name": "brandbase",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check:sitemap": "node scripts/check-sitemap.mjs",
    "check:smoke": "node scripts/smoke-routes.mjs",
    "check:lighthouse": "node scripts/lighthouse-budget.mjs",
    "quality": "npm run lint && npm run build && npm run check:sitemap && npm run check:smoke && npm run check:lighthouse",
    "test": "npm run test:unit && npm run test:smoke",
    "test:unit": "tsx --test tests/**/*.test.ts",
    "test:smoke": "npm run lint && npm run build"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
